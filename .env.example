# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=cafe_bpo
DATABASE_URL=postgresql+psycopg://postgres:your_password@db:5432/cafe_bpo

# Backend Security (generate a random secret: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_random_hex_string
JWT_ALGORITHM=HS256
MODE=development

# Infrastructure
PGADMIN_DEFAULT_EMAIL=admin@cafe.com
PGADMIN_DEFAULT_PASSWORD=admin123

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo

# Microsoft OAuth (opcional)
MICROSOFT_CLIENT_ID=your_ms_client_id
MICROSOFT_CLIENT_SECRET=your_ms_client_secret
MICROSOFT_AUTH_URL=https://login.microsoftonline.com/common/oauth2/v2.0/authorize
MICROSOFT_TOKEN_URL=https://login.microsoftonline.com/common/oauth2/v2.0/token
MICROSOFT_USERINFO_URL=https://graph.microsoft.com/v1.0/me

# OAuth Redirect
OAUTH_REDIRECT_URI=http://localhost:8000/auth
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cloudinary Storage (obtenha suas keys no dashboard do Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

FILE_UPLOAD_MAX_SIZE=5242880
